# YouTube Data API key — used by Content Strategist for competitive research
# Get yours at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your project
YOUTUBE_API_KEY=

# Late.dev API key — used by Publisher for scheduling and publishing content
# Get yours at: https://app.getlate.dev/settings/api
# Key format: sk_ prefix + 64 hex characters
LATE_API_KEY=

# OpenRouter API key — used by Creative Director for thumbnail and image generation
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Supabase — used by Copywriter for blog publishing
# Get yours at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
