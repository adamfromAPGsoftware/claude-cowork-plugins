{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Long-Form Video MG Analysis",
  "description": "Per-video motion graphics analysis for long-form YouTube tutorials. Three-section structure: video metadata, intro analysis (short-form depth), and body analysis (sampled windows).",
  "type": "object",
  "required": ["videoMetadata", "introAnalysis", "bodyAnalysis"],
  "properties": {
    "videoMetadata": {
      "type": "object",
      "required": ["durationSeconds", "creator", "category", "introEndTimestamp", "dominantAesthetic"],
      "properties": {
        "durationSeconds": {
          "type": "number",
          "description": "Total video duration in seconds"
        },
        "creator": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": ["shorter-form", "course-length"],
          "description": "shorter-form = 10-30 min, course-length = 1hr+"
        },
        "introEndTimestamp": {
          "type": "string",
          "description": "MM:SS.s timestamp where intro ends and body begins"
        },
        "chapterCount": {
          "type": "integer",
          "description": "Number of distinct chapters/sections in the full video"
        },
        "totalIntroMGEvents": {
          "type": "integer"
        },
        "totalBodySampleMGEvents": {
          "type": "integer"
        },
        "sampleWindowCount": {
          "type": "integer",
          "description": "Number of body sample windows analyzed"
        },
        "dominantAesthetic": {
          "type": "string",
          "enum": ["dark-mode", "light-mode", "mixed"],
          "description": "Overall visual style of the video"
        }
      }
    },

    "introAnalysis": {
      "type": "object",
      "required": ["hookAnalysis", "motionGraphicEvents", "transitions", "layoutTimeline", "colorPalette", "pacingMetrics"],
      "properties": {
        "hookAnalysis": {
          "type": "object",
          "required": ["hookDurationSeconds", "hookStrategy", "elements"],
          "properties": {
            "hookDurationSeconds": {
              "type": "number",
              "description": "Duration of the hook in seconds (typically first 3-15s)"
            },
            "hookStrategy": {
              "type": "string",
              "description": "Detailed description of the hook's psychological/persuasion approach"
            },
            "elements": {
              "type": "array",
              "items": { "type": "string" },
              "description": "3-5 specific visual/audio elements making up the hook"
            }
          }
        },

        "ctaAnalysis": {
          "type": ["object", "null"],
          "description": "Call-to-action analysis if present in intro",
          "properties": {
            "ctaStartTimestamp": { "type": "string" },
            "ctaStrategy": { "type": "string" },
            "ctaText": { "type": "string" }
          }
        },

        "motionGraphicEvents": {
          "type": "array",
          "description": "Every MG event in the intro at ms-precision (short-form depth)",
          "items": { "$ref": "#/$defs/mgEvent" }
        },

        "transitions": {
          "type": "array",
          "items": { "$ref": "#/$defs/transition" }
        },

        "layoutTimeline": {
          "type": "array",
          "description": "Layout segments at 1-second granularity for intro",
          "items": { "$ref": "#/$defs/layoutSegment" }
        },

        "colorPalette": { "$ref": "#/$defs/colorPalette" },

        "recurringPatterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/recurringPattern" }
        },

        "pacingMetrics": { "$ref": "#/$defs/pacingMetrics" }
      }
    },

    "bodyAnalysis": {
      "type": "object",
      "required": ["bodySampleWindows", "bodyMGPatterns", "sectionTransitions"],
      "properties": {
        "bodySampleWindows": {
          "type": "array",
          "description": "3-7 representative 2-minute windows analyzed at short-form depth",
          "items": {
            "type": "object",
            "required": ["windowStart", "windowEnd", "sectionContext", "motionGraphicEvents", "transitions", "pacingMetrics"],
            "properties": {
              "windowStart": {
                "type": "string",
                "description": "MM:SS start timestamp of the sample window"
              },
              "windowEnd": {
                "type": "string",
                "description": "MM:SS end timestamp of the sample window"
              },
              "sectionContext": {
                "type": "string",
                "description": "What chapter/topic is being covered in this window"
              },
              "primaryLayout": {
                "type": "string",
                "description": "Dominant layout in this window (e.g., screen-share-with-pip, full-frame-speaker)"
              },
              "pipState": {
                "type": "string",
                "enum": ["on", "off", "mixed"],
                "description": "Whether PiP speaker overlay is active in this window"
              },
              "motionGraphicEvents": {
                "type": "array",
                "items": { "$ref": "#/$defs/mgEvent" }
              },
              "transitions": {
                "type": "array",
                "items": { "$ref": "#/$defs/transition" }
              },
              "layoutTimeline": {
                "type": "array",
                "items": { "$ref": "#/$defs/layoutSegment" }
              },
              "zoomEvents": {
                "type": "array",
                "description": "Digital zoom/pan events within the window",
                "items": {
                  "type": "object",
                  "properties": {
                    "timestamp": { "type": "string" },
                    "zoomFactor": { "type": "string", "description": "e.g., '1.0 -> 1.5'" },
                    "panDirection": { "type": "string" },
                    "durationSeconds": { "type": "number" },
                    "easing": { "type": "string" }
                  }
                }
              },
              "mgSpacingSeconds": {
                "type": "object",
                "description": "Spacing between consecutive MG events in this window",
                "properties": {
                  "min": { "type": "number" },
                  "max": { "type": "number" },
                  "avg": { "type": "number" }
                }
              },
              "pacingMetrics": { "$ref": "#/$defs/pacingMetrics" }
            }
          }
        },

        "bodyMGPatterns": {
          "type": "object",
          "description": "Aggregated MG patterns across all body sample windows",
          "properties": {
            "mgTypeDistribution": {
              "type": "object",
              "description": "Count of each MG type (A-G) across body samples",
              "additionalProperties": { "type": "integer" }
            },
            "avgSpacingByLayoutType": {
              "type": "object",
              "description": "Average seconds between MGs when in each layout type",
              "additionalProperties": { "type": "number" }
            },
            "transitionTypeFrequency": {
              "type": "object",
              "additionalProperties": { "type": "integer" }
            },
            "pipToggleFrequency": {
              "type": "string",
              "description": "How often PiP state changes (e.g., 'every 2-3 min')"
            },
            "zoomFrequencyPerMinute": {
              "type": "number"
            },
            "speakerReturnCadenceSeconds": {
              "type": "object",
              "properties": {
                "min": { "type": "number" },
                "max": { "type": "number" },
                "avg": { "type": "number" }
              }
            }
          }
        },

        "sectionTransitions": {
          "type": "array",
          "description": "Every chapter boundary transition in the full video",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string" },
              "fromSection": { "type": "string" },
              "toSection": { "type": "string" },
              "transitionStyle": {
                "type": "string",
                "description": "e.g., 'black title card', 'speaker return + verbal bridge', 'direct cut'"
              },
              "cardDesign": {
                "type": ["object", "null"],
                "description": "If a title/chapter card is used",
                "properties": {
                  "backgroundColor": { "type": "string" },
                  "textColor": { "type": "string" },
                  "fontStyle": { "type": "string" },
                  "durationSeconds": { "type": "number" }
                }
              }
            }
          }
        },

        "ctaAnalysis": {
          "type": ["object", "null"],
          "description": "Mid-roll and end CTA analysis",
          "properties": {
            "midRollCTAs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "timestamp": { "type": "string" },
                  "ctaType": { "type": "string" },
                  "ctaText": { "type": "string" }
                }
              }
            },
            "endCTA": {
              "type": ["object", "null"],
              "properties": {
                "timestamp": { "type": "string" },
                "ctaType": { "type": "string" },
                "ctaText": { "type": "string" },
                "visualDescription": { "type": "string" }
              }
            }
          }
        },

        "mgDensityByChapter": {
          "type": "array",
          "description": "Approximate MG count and spacing per chapter (from density pass)",
          "items": {
            "type": "object",
            "properties": {
              "chapterName": { "type": "string" },
              "startTimestamp": { "type": "string" },
              "endTimestamp": { "type": "string" },
              "durationSeconds": { "type": "number" },
              "approximateMGCount": { "type": "integer" },
              "avgInterMGSpacingSeconds": { "type": "number" },
              "mgSparseZones": {
                "type": "array",
                "description": "Zones >30s without visual change",
                "items": {
                  "type": "object",
                  "properties": {
                    "startTimestamp": { "type": "string" },
                    "endTimestamp": { "type": "string" },
                    "durationSeconds": { "type": "number" },
                    "context": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },

  "$defs": {
    "mgEvent": {
      "type": "object",
      "required": ["startTimestamp", "endTimestamp", "durationSeconds", "category", "visualDescription", "entryAnimation", "exitAnimation", "transcriptCorrelation"],
      "properties": {
        "startTimestamp": {
          "type": "string",
          "description": "MM:SS.s format (e.g., '00:02.3' or '01:45.7')"
        },
        "endTimestamp": { "type": "string" },
        "durationSeconds": { "type": "number" },
        "category": {
          "type": "string",
          "enum": ["text-overlay", "logo-animation", "UI-mockup", "concept-graphic", "sequential-bullets", "stylized-b-roll", "digital-pan-zoom", "counter-number", "diagram", "floating-card", "shape-animation", "comparison-layout"],
          "description": "MG type. Maps to long-form Types A-G: A=text-overlay/counter-number, B=logo-animation, C=UI-mockup, D=concept-graphic/diagram, E=sequential-bullets, F=stylized-b-roll, G=digital-pan-zoom"
        },
        "visualDescription": {
          "type": "string",
          "description": "Detailed visual description (3-5 sentences) sufficient for a Remotion developer to recreate"
        },
        "motionChoreography": {
          "type": "string",
          "description": "Numbered steps with sub-second timing (e.g., '1. Logo scales in over 0.3s. 2. Text fades in below over 0.2s.')"
        },
        "entryAnimation": {
          "type": "string",
          "enum": ["cut-in", "fade-in", "pop-in", "scale-up", "zoom-in", "slide-in-left", "slide-in-right", "slide-in-top", "slide-in-bottom", "typewriter", "wipe-reveal", "spring"]
        },
        "exitAnimation": {
          "type": "string",
          "enum": ["cut-out", "fade-out", "hold-then-cut", "scale-down", "slide-out", "zoom-out"]
        },
        "easing": {
          "type": "string",
          "description": "Easing curve if observable (e.g., 'ease-in-out', 'spring', 'linear')"
        },
        "position": {
          "type": "string",
          "enum": ["center", "top-center", "bottom-center", "top-left", "top-right", "bottom-left", "bottom-right", "full-screen", "left-half", "right-half"]
        },
        "sizeRelative": {
          "type": "string",
          "enum": ["small", "medium", "large", "full"]
        },
        "transcriptCorrelation": {
          "type": "string",
          "description": "Exact words spoken by the narrator during this MG event"
        },
        "textContent": {
          "type": ["string", "null"],
          "description": "Verbatim text displayed in the MG element"
        },
        "fontStyle": {
          "type": ["object", "null"],
          "properties": {
            "fontName": { "type": "string" },
            "weight": { "type": "string" },
            "color": { "type": "string", "description": "Hex color code" },
            "sizeDescription": { "type": "string" },
            "hasShadow": { "type": "boolean" },
            "shadowDesc": { "type": "string" }
          }
        },
        "interactionDetails": {
          "type": ["string", "null"],
          "description": "For interactive MG elements: cursor movements, typing, clicks"
        }
      }
    },

    "transition": {
      "type": "object",
      "required": ["timestamp", "type", "durationSeconds"],
      "properties": {
        "timestamp": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["hard-cut", "jump-cut", "fade", "crossfade", "dissolve", "white-flash", "light-leak", "zoom-transition"]
        },
        "durationSeconds": { "type": "number" },
        "visualDescription": { "type": "string" },
        "hasSoundEffect": { "type": "boolean" }
      }
    },

    "layoutSegment": {
      "type": "object",
      "required": ["startTimestamp", "endTimestamp", "layout"],
      "properties": {
        "startTimestamp": { "type": "string" },
        "endTimestamp": { "type": "string" },
        "layout": {
          "type": "string",
          "enum": ["full-frame-speaker", "full-frame-screen-share", "pip-speaker-over-screen-share", "pip-screen-share-over-speaker", "split-screen", "title-chapter-card", "graphic-overlay-on-speaker", "full-screen-graphic", "concept-slide-with-pip"]
        },
        "zoneDescriptions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "colorPalette": {
      "type": "object",
      "properties": {
        "backgroundColors": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Hex codes for background colors observed"
        },
        "textColors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "accentColors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "brandObservations": {
          "type": "string",
          "description": "Notes on color strategy and brand consistency"
        }
      }
    },

    "recurringPattern": {
      "type": "object",
      "required": ["patternName", "description", "occurrenceCount"],
      "properties": {
        "patternName": { "type": "string" },
        "description": { "type": "string" },
        "occurrenceCount": { "type": "integer" },
        "timestamps": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "pacingMetrics": {
      "type": "object",
      "properties": {
        "averageSceneDurationSeconds": { "type": "number" },
        "shortestSceneDurationSeconds": { "type": "number" },
        "longestSceneDurationSeconds": { "type": "number" },
        "mgSecondsTotal": { "type": "number" },
        "speakerSecondsTotal": { "type": "number" },
        "cutsPerMinute": { "type": "number" },
        "sceneDurationDistribution": { "type": "string" }
      }
    }
  }
}
