# ═══════════════════════════════════════════════════════════════════════════════
# Public Claude Cowork Plugins — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values for the plugins you use.
# You only need the keys for the plugins you plan to activate.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Sales Plugin ─────────────────────────────────────────────────────────────
# Fathom API — for syncing meeting transcripts
# Get yours at: https://fathom.video/settings/api
FATHOM_API_KEY=

# ─── Audit Plugin ─────────────────────────────────────────────────────────────
# Cloudflare — for deploying client portal pages
# Get yours at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ─── Content Plugin ───────────────────────────────────────────────────────────
# YouTube Data API — for competitive research
# Get yours at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your project
YOUTUBE_API_KEY=

# Late.dev API — for scheduling and publishing content
# Get yours at: https://app.getlate.dev/settings/api
LATE_API_KEY=

# OpenRouter API — for AI model access (image generation, analysis)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Supabase — for blog publishing and asset hosting
# Get yours at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─── Marketing Plugin ────────────────────────────────────────────────────────
# Meta Marketing API — for pulling ad campaign data
# Get yours at: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=

# Google Analytics 4 — for landing page analytics
# Get property ID from: GA4 Admin → Property Settings
GA4_PROPERTY_ID=
GA4_PROPERTY_ID_HOME=
GOOGLE_APPLICATION_CREDENTIALS=ga4-service-account.json

# ─── Video Plugin ─────────────────────────────────────────────────────────────
# DeepGram API — for transcription (Nova-3 model)
# Get yours at: https://console.deepgram.com
DEEPGRAM_API_KEY=

# Hera Video API — for motion graphic generation
HERA_API_KEY=

# ─── Finance Plugin ──────────────────────────────────────────────────────────
# Airwallex API — for pulling bank transactions and balances
# Get yours at: https://www.airwallex.com/app/account/api
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_ENVIRONMENT=demo

# ─── Social Plugin ───────────────────────────────────────────────────────────
# Instagram Graph API — for managing DMs and comments
# Requires: instagram_manage_messages (advanced access), instagram_manage_comments
# Get token via: https://developers.facebook.com/tools/explorer/
#
# Add one block per Instagram account you want to manage:

# Account 1 (e.g., personal brand)
INSTAGRAM_ACCESS_TOKEN_ACCOUNT_1=
INSTAGRAM_PAGE_ID_ACCOUNT_1=
INSTAGRAM_IG_USER_ID_ACCOUNT_1=

# Account 2 (e.g., business)
INSTAGRAM_ACCESS_TOKEN_ACCOUNT_2=
INSTAGRAM_PAGE_ID_ACCOUNT_2=
INSTAGRAM_IG_USER_ID_ACCOUNT_2=

# ─── Gmail Integration (used by Sales + Audit plugins) ───────────────────────
# Google OAuth — for drafting emails in Gmail
# Set up at: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
