# ═══════════════════════════════════════════════════════════════════════════════
# Sales Plugin — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env in the repo root and fill in your values.
# Run /sales:setup first to configure your business settings interactively.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Google Sheets (service account — headless, no browser needed) ────────────
# How to get: GCP Console → IAM & Admin → Service Accounts → Create key (JSON)
# Then share your Google Sheet with the service account email address.
# Full guide: sales-plugin/scripts/sheets-auth-setup.md
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=

# ─── Gmail (OAuth — browser consent fires automatically on first sync) ────────
# How to get: GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Enable: Gmail API, Google Calendar API
# Redirect URI: http://localhost:8080
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_SEND_AS=                  # The Gmail address you send from

# ─── Twilio (SMS history + click-to-call bridge) ──────────────────────────────
# How to get: console.twilio.com → Account SID and Auth Token
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=             # E.164 format: +1xxxxxxxxxx

# ─── Fathom (meeting transcript sync) ─────────────────────────────────────────
# How to get: fathom.video → Settings → API
FATHOM_API_KEY=

# ─── Optional: OpenRouter (call recording transcription via Whisper) ──────────
# How to get: openrouter.ai/keys
OPENROUTER_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# Content Plugin — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# The content plugin uses platform-level MCP servers (YouTube, fal-ai, Buffer, Exa).
# No API keys needed here — MCPs are connected at the Claude Code platform level.

# ═══════════════════════════════════════════════════════════════════════════════
# Marketing Plugin — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Meta Marketing API ────────────────────────────────────────────────────────
# How to get: business.facebook.com → Settings → System Users → Generate Token
# Permissions needed: ads_management, ads_read, business_management
META_ACCESS_TOKEN=

# ─── Cloudflare (landing page deployment) ─────────────────────────────────────
# How to get: dash.cloudflare.com → Profile → API Tokens → Create Token
# Account ID: shown in right sidebar on dash.cloudflare.com
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ─── fal.ai (video generation — optional) ─────────────────────────────────────
# How to get: fal.ai/dashboard/keys
FAL_API_KEY=

# ─── Apify (competitor scraping — optional) ────────────────────────────────────
# How to get: console.apify.com/account/integrations
APIFY_API_TOKEN=

# ─── Google Analytics 4 (optional) ───────────────────────────────────────────
# How to get: See marketing-plugin/SETUP.md → "Setting Up Google Analytics 4"
GOOGLE_APPLICATION_CREDENTIALS=ga4-service-account.json
GA4_PROPERTY_ID=
GA4_PROPERTY_ID_HOME=

# ═══════════════════════════════════════════════════════════════════════════════
# Video Plugin — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Deepgram (transcription — Nova-3 model) ──────────────────────────────────
# How to get: deepgram.com/developers → API Keys → Create a New API Key
DEEPGRAM_API_KEY=

# ─── Hera (motion graphic generation) ────────────────────────────────────────
# How to get: contact Hera for API access
HERA_API_KEY=

# ─── Supabase Storage (reference image hosting for Hera API) ─────────────────
# Reuse values from Content Plugin above if already configured
# SUPABASE_URL=       (shared with content plugin)
SUPABASE_SERVICE_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# PM Plugin — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Run /pm:setup first — it writes pm-plugin/config.yaml interactively.
# The only env vars the PM plugin needs are for optional integrations.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Fathom (optional — meeting transcript sync) ──────────────────────────────
# How to get: fathom.video → Settings → API
# Enable in setup: integrations.fathom.enabled: true
# FATHOM_API_KEY=       (shared with Sales Plugin if already set above)
