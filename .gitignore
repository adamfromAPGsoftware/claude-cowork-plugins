*.pyc
.wrangler/
staging/
dist/
SANITIZE_REPORT.txt
SANITIZE_DIFF.txt

# Sales plugin runtime data
sales-plugin/data/leads.json
sales-plugin/data/pending-drafts.json
sales-plugin/data/followup-approved.json
sales-plugin/data/send-log.jsonl
sales-plugin/data/pipeline-kanban.html
sales-plugin/data/recordings/
