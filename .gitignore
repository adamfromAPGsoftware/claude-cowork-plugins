# Video plugin runtime data (all data is user-generated at runtime)
video-plugin/data/*
!video-plugin/data/.gitkeep
!video-plugin/data/.gitignore

# PM plugin runtime data (all client data is user-generated at runtime)
pm-plugin/data/clients/
pm-plugin/data/.memory/
!pm-plugin/data/.gitkeep
!pm-plugin/data/.gitignore
