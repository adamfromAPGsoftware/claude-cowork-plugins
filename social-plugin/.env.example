# ═══════════════════════════════════════════════════════════════════
# APG Social Plugin — Environment Variables
# ═══════════════════════════════════════════════════════════════════
#
# NOTE: These tokens are DIFFERENT from META_ACCESS_TOKEN (which has ads_read).
# The social plugin needs instagram_manage_messages + instagram_manage_comments.
#
# How to get credentials:
#   1. Instagram Business or Creator account linked to a Facebook Page
#   2. Meta Developer App with required permissions
#   3. Generate Page Access Token via Graph API Explorer
#   4. Get IG User ID: GET /me?fields=id via Instagram Graph API
#   5. Request Advanced Access for instagram_manage_messages
#
# Required Meta App permissions:
#   - instagram_manage_messages (advanced access required)
#   - instagram_manage_comments
#   - instagram_basic
#   - pages_manage_metadata
#   - pages_read_engagement

# ─── Instagram Account: adamgoodyer (Personal Brand) ─────────────
INSTAGRAM_ACCESS_TOKEN_ADAM=
INSTAGRAM_PAGE_ID_ADAM=           # Optional — only needed for webhook subscriptions
INSTAGRAM_IG_USER_ID_ADAM=

# ─── Instagram Account: apgsoftware (Business) ──────────────────
INSTAGRAM_ACCESS_TOKEN_APG=
INSTAGRAM_PAGE_ID_APG=           # Optional — only needed for webhook subscriptions
INSTAGRAM_IG_USER_ID_APG=

# ─── Rate Limiting (optional overrides) ─────────────────────────
# INSTAGRAM_DM_RATE_LIMIT_PER_HOUR=200
